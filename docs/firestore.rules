rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /network_users/{userId} {
      // Anyone logged in can read profile data
      allow read: if request.auth != null;

      // Users can create their own initial profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // Verification logic:
      // 1. Users can update their own basic info (not status or verifiedBy)
      // 2. Verified users can update OTHER users' verification status
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/network_users/$(request.auth.uid)).data.status in ['VERIFIED', 'SELF_VERIFIED']
      );
    }
  }
}
