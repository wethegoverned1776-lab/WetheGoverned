<resources>
    <!-- Base application theme. -->
    <style name="Theme.WeTheGoverned" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Post-splash theme for the main activity -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- The background of the splash screen icon -->
        <item name="windowSplashScreenBackground">@color/white</item>
        <!-- The icon to be displayed. If not specified, the app icon is used -->
        <!-- <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item> -->
        <!-- Theme to be applied after the splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.WeTheGoverned</item>
    </style>
</resources>