<resources>
    <!--  System launch theme: shows splash_background ONLY during cold start
             before MainActivity is ready. Android 12+ uses this briefly.  -->
    <style name="Theme.WeTheGoverned.Launching" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <!--  Main App Theme: NO splash background. Used once app is running.  -->
    <style name="Theme.WeTheGoverned" parent="android:Theme.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>