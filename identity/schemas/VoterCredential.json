{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "https://wethegoverned.org/schemas/voter-credential-v1.json",
  "title": "U.S. District Voter Credential",
  "description": "A verifiable credential representing a user's verified status in a U.S. Congressional District.",
  "type": "object",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's DID (e.g., did:pkh:eip155:1:...)" },
        "district": { "type": "string", "description": "The Congressional District code (e.g., FL-06)" },
        "isOver18": { "type": "boolean" },
        "isUSCitizen": { "type": "boolean" },
        "verificationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "district", "isOver18", "isUSCitizen"]
    }
  }
}
